{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#D97757",
          "style": "plain",
          "template": "🐱 ",
          "type": "text"
        },
        {
          "foreground": "#C15F3C",
          "style": "plain",
          "template": "{{ .UserName }} ",
          "type": "session"
        },
        {
          "foreground": "#FAF9F5",
          "options": {
            "style": "full"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#73D0FF",
          "style": "plain",
          "template": "({{ .Venv }}) ",
          "type": "python"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#A8B5A0",
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "{{ .UpstreamIcon }} {{ .HEAD }}{{ if .Working.Changed }} <#D29922>*</>{{ end }}{{ if .Staging.Changed }} +{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "overflow": "hide",
      "segments": [
        {
          "foreground": "#6B6B6B",
          "options": {
            "style": "austin",
            "threshold": 0
          },
          "style": "plain",
          "template": "{{ .FormattedMs }} ",
          "type": "executiontime"
        },
        {
          "foreground": "#9A9B8C",
          "style": "plain",
          "template": "MEM: {{ round .PhysicalPercentUsed .Precision }}% ",
          "type": "sysinfo",
          "cache_duration": "5s"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#D97757",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#E05050{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "❯ ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}(Admin){{end}} {{.PWD}}",
  "transient_prompt": {
    "foreground": "#D97757",
    "foreground_templates": [
      "{{ if gt .Code 0 }}#E05050{{ end }}"
    ],
    "template": "❯ "
  },
  "version": 4
}