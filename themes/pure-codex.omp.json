{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#58A6FF",
          "style": "plain",
          "template": "⚛️ ",
          "type": "text"
        },
        {
          "foreground": "#8B949E",
          "style": "plain",
          "template": "{{ .UserName }} ",
          "type": "session"
        },
        {
          "foreground": "#F0F6FC",
          "options": {
            "style": "full"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#D97757",
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "{{ .UpstreamIcon }} {{ .HEAD }}{{ if .Working.Changed }} <#F85149>*</>{{ end }}{{ if .Staging.Changed }} +{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "overflow": "hide",
      "segments": [
        {
          "foreground": "#6E7681",
          "options": {
            "style": "austin",
            "threshold": 0
          },
          "style": "plain",
          "template": "{{ .FormattedMs }} ",
          "type": "executiontime"
        },
        {
          "foreground": "#D29922",
          "style": "plain",
          "template": "MEM: {{ round .PhysicalPercentUsed .Precision }}% ",
          "type": "sysinfo",
          "cache_duration": "5s"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#7EE787",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#F85149{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "❯ ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}(Admin){{end}} {{.PWD}}",
  "transient_prompt": {
    "foreground": "#7EE787",
    "foreground_templates": [
      "{{ if gt .Code 0 }}#F85149{{ end }}"
    ],
    "template": "❯ "
  },
  "version": 4
}